# =============================================================================
# Multi-stage Dockerfile for Next.js
# Same pattern as the API Dockerfile: build in a heavy image, run in a slim one.
# =============================================================================

# ── Stage 1: install dependencies ─────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

# Copy package files first so Docker can cache this layer.
# If package.json hasn't changed, the npm install layer is reused on rebuilds.
COPY package.json package-lock.json* ./

# npm ci is faster and stricter than npm install — it requires a lock file and
# never modifies it. If no lock file exists yet, fall back to npm install.
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi


# ── Stage 2: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_ variables are baked into the JavaScript bundle at compile time.
# The browser downloads this JS — it has no access to container env vars.
# So the API URL must be embedded here, not set at container startup.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Disable Next.js telemetry (data collection) during build
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build


# ── Stage 3: production runner ─────────────────────────────────────────────────
# Starts from a fresh minimal image. Nothing from the builder except the output.
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Non-root user — same security reasoning as the API Dockerfile
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# The 'standalone' output (configured in next.config.mjs) puts everything needed
# to run the server into .next/standalone — no node_modules folder required.
# mkdir -p ensures the copy doesn't fail if public/ happens to be empty.
RUN mkdir -p ./public
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# server.js is generated by Next.js as part of the standalone output
CMD ["node", "server.js"]
